{
    "files.associations": {
        "*.html": "liquid",
        "*.liquid": "liquid",
        "*.md": "liquid",
        "*.js": "liquid-javascript",
        "*.scss": "liquid-scss"
    },
    "editor.tabSize": 2,
    "cSpell.enabledFileTypes": {
        "javascript": false
    },
    "javascript.validate.enable": false,
    "cSpell.words": [
        "Vajrayāna"
    ],
    "python-envs.pythonProjects": [
        {
            "path": "scripts"
        }
    ],
    "python.defaultInterpreterPath": "../obu/bin/python",
    "python.autoComplete.extraPaths": [
        "scripts"
    ],
    "python.pyrefly.configPath": "pyrefly.toml"
}